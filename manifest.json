{
  "manifest_version": 3,
  "name": "Aburrido AI",
  "version": "1.0.0",
  "description": "AI-powered job application agent for LinkedIn and Indeed",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms",
    "identity"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.indeed.com/*",
    "https://api.anthropic.com/*",
    "https://ceuymsrfthlcieapftsv.supabase.co/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/ai_helper.js", "content/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.indeed.com/*"],
      "js": ["content/ai_helper.js", "content/indeed.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html", "dashboard/dashboard.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
